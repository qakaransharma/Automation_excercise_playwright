{
  "name": "automation_excercise_playwright",
  "version": "1.0.0",
  "description": "Playwright automation framework for automationexercise.com",
  "keywords": [
    "playwright",
    "automation",
    "testing"
  ],
  "homepage": "https://github.com/qakaransharma/Automation_excercise_playwright#readme",
  "bugs": {
    "url": "https://github.com/qakaransharma/Automation_excercise_playwright/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qakaransharma/Automation_excercise_playwright.git"
  },
  "license": "ISC",
  "author": "Karan Sharma",
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:setup": "npx playwright test tests/auth.setup.ts",
    "test:stage": "cross-env ENV=stage npx playwright test",
    "test:qa": "cross-env ENV=qa npx playwright test && npm run allure:generate && npm run allure:open",
    "report:playwright": "npx playwright show-report",
    "allure:generate": "allure generate reports/allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-report",
    "clean:allure": "if exist reports\\allure-results (rmdir /s /q reports\\allure-results) && if exist allure-report (rmdir /s /q allure-report)",
    "clean:auth": "if exist auth (rmdir /s /q auth)",
    "clean:logs": "if exist logs (rmdir /s /q logs)",
    "docker:build": "docker compose build",
    "docker:test": "docker compose up --abort-on-container-exit",
    "docker:test:qa": "cross-env ENV=qa docker compose up --abort-on-container-exit",
    "docker:test:stage": "cross-env ENV=stage docker compose up --abort-on-container-exit",
    "docker:clean": "docker compose down --rmi local"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.10.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1",
    "playwright-core": "^1.61.1",
    "prettier": "^3.8.3",
    "typescript": "^7.0.2",
    "winston": "^3.19.0"
  }
}
