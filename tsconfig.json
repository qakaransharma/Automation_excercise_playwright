{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@config/*": ["./src/config/*"],
      "@fixtures/*": ["./src/fixture/*"],
      "@test-data/*": ["./test-data/*"]
    }
  },
  "include": ["**/*.ts"]
}
